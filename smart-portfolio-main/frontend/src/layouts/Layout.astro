---
import "@/styles/style.css";
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MorningStar | Developer",
  description = "Developer specializing in frontend architecture, React, and AI.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0&icon_names=waving_hand" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0&icon_names=handshake" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0&icon_names=rocket_launch" />
    <title>{title}</title>
    <style is:global>
      :root {
        --font-mono: 'JetBrains Mono', monospace;
        --font-sans: 'Inter', sans-serif;
      }
      body {
        font-family: var(--font-sans);
        /* Cursor restored to default */
        cursor: auto; 
      }
      /* Ensure interactive elements use standard pointers */
      a, button, [role="button"] {
        cursor: pointer !important;
      }
      .font-mono {
        font-family: var(--font-mono);
      }
      .section-bg-layer {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 650ms ease;
      }

      /* View Transition Styles for Theme Toggle */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
      }
      ::view-transition-old(root) {
        z-index: 1;
      }
      ::view-transition-new(root) {
        z-index: 2;
      }

      /* RESPONSIVE OVERRIDES */
      @media (max-width: 1024px) {
        #page-scrollbar {
          display: none !important;
        }
        /* Disable snapping if sections are too tall for small screens to prevent content cutoff */
        body.snap-y {
          scroll-snap-type: none !important;
        }
      }

      @media (max-width: 768px) {
        /* Global Typography Scaling for Mobile */
        h1 { font-size: 2.25rem !important; line-height: 2.5rem !important; letter-spacing: -0.02em !important; }
        h2 { font-size: 1.75rem !important; line-height: 2rem !important; }
        h3 { font-size: 1.25rem !important; line-height: 1.75rem !important; }
        p { font-size: 0.9375rem !important; line-height: 1.5rem !important; }
        
        /* Utility Class Overrides for Mobile */
        .text-6xl { font-size: 3rem !important; line-height: 1 !important; }
        .text-5xl { font-size: 2.5rem !important; line-height: 1 !important; }
        .text-4xl { font-size: 2rem !important; line-height: 2.25rem !important; }
        
        /* Grid and spacing adjustments */
        .container { padding-left: 1.25rem !important; padding-right: 1.25rem !important; }
        
        .section-bg-layer {
          background-size: 30px 30px !important;
        }
      }

      @media (max-width: 480px) {
        h1 { font-size: 1.875rem !important; }
        .text-base { font-size: 0.875rem !important; }
      }
    </style>
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark';
      })();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen overflow-x-hidden text-foreground antialiased relative snap-y snap-mandatory">
    <!-- Custom Cursor Elements Removed per Request -->

    <div id="section-bg-stage" class="fixed inset-0 pointer-events-none z-0 overflow-hidden bg-background">
      <div data-bg-id="default" class="section-bg-layer opacity-100">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.05)_1px,transparent_1px),linear-gradient(to_bottom,rgba(0,0,0,0.05)_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
      </div>
      <div data-bg-id="about" class="section-bg-layer">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(0,163,84,0.12),transparent_32%),radial-gradient(circle_at_85%_18%,rgba(255,140,0,0.12),transparent_22%)] dark:bg-[radial-gradient(circle_at_top_left,rgba(255,140,0,0.14),transparent_32%),radial-gradient(circle_at_85%_18%,rgba(0,163,84,0.1),transparent_22%)]"></div>
        <div class="absolute inset-y-0 right-[12%] w-px bg-[linear-gradient(to_bottom,transparent,rgba(0,0,0,0.18),transparent)] dark:bg-[linear-gradient(to_bottom,transparent,rgba(255,255,255,0.16),transparent)]"></div>
        <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(0,0,0,0.05)_1px,transparent_1px)] dark:bg-[linear-gradient(135deg,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:32px_32px] opacity-60"></div>
      </div>
      <div data-bg-id="experience" class="section-bg-layer">
        <div class="absolute inset-0 bg-[repeating-linear-gradient(90deg,rgba(0,0,0,0.05),rgba(0,0,0,0.05)_1px,transparent_1px,transparent_56px)] dark:bg-[repeating-linear-gradient(90deg,rgba(255,255,255,0.06),rgba(255,255,255,0.06)_1px,transparent_1px,transparent_56px)]"></div>
        <div class="absolute left-0 right-0 top-[22%] h-px bg-[linear-gradient(to_right,transparent,rgba(0,163,84,0.4),transparent)] dark:bg-[linear-gradient(to_right,transparent,rgba(255,140,0,0.42),transparent)]"></div>
        <div class="absolute -left-16 bottom-12 h-48 w-48 rounded-full bg-brand-green/8 blur-3xl dark:bg-brand-orange/10"></div>
      </div>
      <div data-bg-id="projects" class="section-bg-layer">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_22%,rgba(0,163,84,0.08),transparent_18%),radial-gradient(circle_at_78%_78%,rgba(255,140,0,0.1),transparent_24%)] dark:bg-[radial-gradient(circle_at_20%_22%,rgba(255,140,0,0.12),transparent_18%),radial-gradient(circle_at_78%_78%,rgba(0,163,84,0.08),transparent_24%)]"></div>
        <div class="absolute inset-0 bg-[repeating-linear-gradient(135deg,transparent,transparent_18px,rgba(0,0,0,0.045)_18px,rgba(0,0,0,0.045)_19px)] dark:bg-[repeating-linear-gradient(135deg,transparent,transparent_18px,rgba(255,255,255,0.05)_18px,rgba(255,255,255,0.05)_19px)] opacity-80"></div>
      </div>
      <div data-bg-id="chat" class="section-bg-layer">
        <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(0,163,84,0.06),transparent_20%,transparent_80%,rgba(0,0,0,0.04)),repeating-linear-gradient(to_bottom,transparent,transparent_28px,rgba(0,0,0,0.05)_28px,rgba(0,0,0,0.05)_29px)] dark:bg-[linear-gradient(to_bottom,rgba(255,140,0,0.08),transparent_20%,transparent_80%,rgba(255,255,255,0.03)),repeating-linear-gradient(to_bottom,transparent,transparent_28px,rgba(255,255,255,0.06)_28px,rgba(255,255,255,0.06)_29px)]"></div>
        <div class="absolute right-[10%] top-[14%] h-32 w-32 rounded-full border border-brand-green/25 dark:border-brand-orange/30"></div>
      </div>
      <div data-bg-id="contact" class="section-bg-layer">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(0,163,84,0.1),transparent_24%),linear-gradient(115deg,transparent_0%,transparent_56%,rgba(0,0,0,0.05)_56%,rgba(0,0,0,0.05)_57%,transparent_57%)] dark:bg-[radial-gradient(circle_at_bottom_left,rgba(255,140,0,0.12),transparent_24%),linear-gradient(115deg,transparent_0%,transparent_56%,rgba(255,255,255,0.06)_56%,rgba(255,255,255,0.06)_57%,transparent_57%)]"></div>
        <div class="absolute left-[8%] top-[18%] h-20 w-20 rotate-12 border border-brand-green/25 dark:border-brand-orange/30"></div>
      </div>
      <div data-bg-id="admin" class="section-bg-layer">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(0,163,84,0.08),transparent_24%),radial-gradient(circle_at_bottom_left,rgba(255,140,0,0.1),transparent_28%)] dark:bg-[radial-gradient(circle_at_top_right,rgba(255,140,0,0.12),transparent_24%),radial-gradient(circle_at_bottom_left,rgba(0,163,84,0.08),transparent_28%)]"></div>
        <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.045)_1px,transparent_1px),linear-gradient(to_bottom,rgba(0,0,0,0.045)_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:56px_56px]"></div>
        <div class="absolute inset-y-10 left-1/2 w-px -translate-x-1/2 bg-[linear-gradient(to_bottom,transparent,rgba(0,0,0,0.16),transparent)] dark:bg-[linear-gradient(to_bottom,transparent,rgba(255,255,255,0.16),transparent)]"></div>
      </div>
    </div>
    
    <div class="relative z-10 flex flex-col min-h-screen bg-transparent">
      <slot />
    </div>

    <!-- Page Scrollbar Element -->
    <div id="page-scrollbar" class="fixed right-1 top-0 bottom-0 w-1.5 z-[9999] pointer-events-auto">
      <div class="custom-scrollbar-thumb w-full bg-foreground/20 hover:bg-foreground/40 rounded-full transition-colors cursor-pointer"></div>
    </div>

    <script>
      // Cursor initialization function removed as requested

      function initSectionBackground(): void {
        const layers = Array.from(document.querySelectorAll<HTMLElement>('[data-bg-id]'));
        const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-bg-layer]'));
        if (layers.length === 0 || sections.length === 0) return;

        const setActive = (id: string) => {
          layers.forEach((layer) => {
            layer.style.opacity = layer.dataset.bgId === id ? '1' : '0';
          });
        };

        const observer = new IntersectionObserver((entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (!visible) return;
          setActive((visible.target as HTMLElement).dataset.bgLayer || 'default');
        }, {
          threshold: [0.2, 0.4, 0.6, 0.8],
          rootMargin: '-20% 0px -20% 0px',
        });

        sections.forEach((section) => observer.observe(section));
        const initialSection = sections[0];
        setActive(initialSection ? (initialSection.dataset.bgLayer || 'default') : 'default');
      }

      function attachScrollbar(
        scrollable: Window | HTMLElement,
        root: HTMLElement,
        orientation: 'vertical' | 'horizontal',
      ): void {
        const thumb = root.querySelector<HTMLElement>('.custom-scrollbar-thumb');
        if (!thumb || window.matchMedia("(max-width: 1024px)").matches) return;

        const isWindowTarget = scrollable === window;
        const html = document.documentElement;
        const body = document.body;
        let isDragging = false;
        let activePointerId: number | null = null;
        let pointerOffset = 0;
        let suppressTrackClick = false;
        let restoreScrollBehavior = '';
        let restoreSnapType = '';
        let resizeObserver: ResizeObserver | null = null;
        let mutationObserver: MutationObserver | null = null;

        const getMetrics = () => {
          if (isWindowTarget) {
            const viewport = html.clientHeight;
            const scrollSize = html.scrollHeight;
            const scrollPos = window.scrollY || html.scrollTop || body.scrollTop || 0;
            const trackSize = orientation === 'vertical' ? root.clientHeight : root.clientWidth;
            return { viewport, scrollSize, scrollPos, trackSize };
          }

          const element = scrollable as HTMLElement;
          if (orientation === 'vertical') {
            return {
              viewport: element.clientHeight,
              scrollSize: element.scrollHeight,
              scrollPos: element.scrollTop,
              trackSize: root.clientHeight,
            };
          }

          return {
            viewport: element.clientWidth,
            scrollSize: element.scrollWidth,
            scrollPos: element.scrollLeft,
            trackSize: root.clientWidth,
          };
        };

        const setScroll = (value: number) => {
          if (isWindowTarget) {
            window.scrollTo(0, value);
            return;
          }

          const element = scrollable as HTMLElement;
          if (orientation === 'vertical') {
            element.scrollTop = value;
          } else {
            element.scrollLeft = value;
          }
        };

        const update = () => {
          const { viewport, scrollSize, scrollPos, trackSize } = getMetrics();
          const maxScroll = Math.max(scrollSize - viewport, 0);
          if (maxScroll <= 0 || trackSize <= 0) {
            root.classList.add('is-hidden');
            return;
          }

          root.classList.remove('is-hidden');
          const minThumbSize = orientation === 'vertical' ? 32 : 48;
          const thumbSize = Math.max((viewport / scrollSize) * trackSize, minThumbSize);
          const maxThumbOffset = Math.max(trackSize - thumbSize, 0);
          const thumbOffset = maxScroll > 0 ? (scrollPos / maxScroll) * maxThumbOffset : 0;

          if (orientation === 'vertical') {
            thumb.style.height = `${thumbSize}px`;
            thumb.style.transform = `translate3d(0, ${thumbOffset}px, 0)`;
          } else {
            thumb.style.width = `${thumbSize}px`;
            thumb.style.transform = `translate3d(${thumbOffset}px, 0, 0)`;
          }
        };

        const applyPointerScroll = (event: PointerEvent) => {
          const rect = root.getBoundingClientRect();
          const pointerPos = orientation === 'vertical' ? event.clientY - rect.top : event.clientX - rect.left;
          const { viewport, scrollSize, trackSize } = getMetrics();
          const maxScroll = Math.max(scrollSize - viewport, 0);
          const minThumbSize = orientation === 'vertical' ? 32 : 48;
          const thumbSize = Math.max((viewport / scrollSize) * trackSize, minThumbSize);
          const maxThumbOffset = Math.max(trackSize - thumbSize, 0);
          const clampedThumbOffset = Math.min(Math.max(pointerPos - pointerOffset, 0), maxThumbOffset);
          const nextScroll = maxThumbOffset > 0 ? (clampedThumbOffset / maxThumbOffset) * maxScroll : 0;
          setScroll(nextScroll);
          update();
        };

        const stopDrag = (event?: PointerEvent) => {
          if (!isDragging) return;
          if (event && activePointerId !== null && event.pointerId !== activePointerId) return;
          isDragging = false;
          activePointerId = null;
          thumb.classList.remove('is-dragging');
          
          const scrollTargetElement = isWindowTarget ? html : (scrollable as HTMLElement);
          scrollTargetElement.style.scrollBehavior = restoreScrollBehavior;
          body.style.scrollSnapType = restoreSnapType;
          
          window.removeEventListener('pointermove', onPointerMove);
          window.removeEventListener('pointerup', stopDrag);
          window.removeEventListener('pointercancel', stopDrag);
          window.setTimeout(() => {
            suppressTrackClick = false;
          }, 0);
        };

        const onPointerMove = (event: PointerEvent) => {
          if (!isDragging) return;
          if (activePointerId !== null && event.pointerId !== activePointerId) return;
          event.preventDefault();
          suppressTrackClick = true;
          applyPointerScroll(event);
        };

        thumb.addEventListener('pointerdown', (event) => {
          if (event.button !== 0) return;
          event.preventDefault();
          event.stopPropagation();
          const rect = thumb.getBoundingClientRect();
          pointerOffset = orientation === 'vertical' ? event.clientY - rect.top : event.clientX - rect.left;
          activePointerId = event.pointerId;
          isDragging = true;
          suppressTrackClick = false;
          
          const scrollTargetElement = isWindowTarget ? html : (scrollable as HTMLElement);
          restoreScrollBehavior = scrollTargetElement.style.scrollBehavior;
          restoreSnapType = body.style.scrollSnapType;
          
          scrollTargetElement.style.scrollBehavior = 'auto';
          body.style.scrollSnapType = 'none';
          
          thumb.classList.add('is-dragging');
          thumb.setPointerCapture(event.pointerId);
          window.addEventListener('pointermove', onPointerMove, { passive: false });
          window.addEventListener('pointerup', stopDrag);
          window.addEventListener('pointercancel', stopDrag);
        });

        thumb.addEventListener('dragstart', (event) => event.preventDefault());

        root.addEventListener('pointerdown', (event) => {
          if (event.button !== 0) return;
          if (event.target === thumb) return;
          event.preventDefault();
          const rect = root.getBoundingClientRect();
          const { viewport, scrollSize, trackSize } = getMetrics();
          const minThumbSize = orientation === 'vertical' ? 32 : 48;
          const thumbSize = Math.max((viewport / scrollSize) * trackSize, minThumbSize);
          const pointerPos = orientation === 'vertical' ? event.clientY - rect.top : event.clientX - rect.left;
          pointerOffset = thumbSize / 2;
          const clampedThumbOffset = Math.min(Math.max(pointerPos - pointerOffset, 0), Math.max(trackSize - thumbSize, 0));
          const maxScroll = Math.max(scrollSize - viewport, 0);
          const nextScroll = trackSize > thumbSize ? (clampedThumbOffset / (trackSize - thumbSize)) * maxScroll : 0;
          setScroll(nextScroll);
          update();
        });

        root.addEventListener('click', (event) => {
          if (!suppressTrackClick) return;
          event.preventDefault();
          event.stopPropagation();
        });

        const scrollTarget: Window | HTMLElement = isWindowTarget ? window : (scrollable as HTMLElement);
        scrollTarget.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);

        if (!isWindowTarget) {
          const element = scrollable as HTMLElement;
          resizeObserver = new ResizeObserver(update);
          resizeObserver.observe(element);
          resizeObserver.observe(root);
          mutationObserver = new MutationObserver(update);
          mutationObserver.observe(element, { childList: true, subtree: true, characterData: true });
        } else {
          resizeObserver = new ResizeObserver(update);
          resizeObserver.observe(html);
          resizeObserver.observe(root);
        }

        update();
      }

      function initCustomScrollbars(): void {
        const pageScrollbar = document.getElementById('page-scrollbar');
        if (pageScrollbar) {
          attachScrollbar(window, pageScrollbar, 'vertical');
        }

        const scrollbars = Array.from(document.querySelectorAll<HTMLElement>('[data-scrollbar-for]'));
        scrollbars.forEach((root) => {
          const targetId = root.dataset.scrollbarFor;
          if (!targetId) return;
          const target = document.getElementById(targetId);
          if (!target) return;
          const orientation = root.dataset.scrollbarOrientation === 'horizontal' ? 'horizontal' : 'vertical';
          attachScrollbar(target, root, orientation);
        });
      }

      initSectionBackground();
      initCustomScrollbars();

      // Global Theme Toggle with Native View Transitions
      (window as any).toggleTheme = function(e: MouseEvent, nextTheme: string) {
        const html = document.documentElement;
        const isDark = html.classList.contains("dark");
        if ((isDark && nextTheme === 'dark') || (!isDark && nextTheme === 'light')) return;

        const performToggle = () => {
          if (nextTheme === 'dark') {
            html.classList.add('dark');
          } else {
            html.classList.remove('dark');
          }
          localStorage.setItem('theme', nextTheme);
          document.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: nextTheme } }));
        };

        if (!(document as any).startViewTransition) {
          performToggle();
          return;
        }

        const x = e.clientX;
        const y = e.clientY;
        const endRadius = Math.hypot(
          Math.max(x, window.innerWidth - x),
          Math.max(y, window.innerHeight - y)
        );

        const transition = (document as any).startViewTransition(performToggle);

        transition.ready.then(() => {
          const clipPath = [
            `circle(0px at ${x}px ${y}px)`,
            `circle(${endRadius}px at ${x}px ${y}px)`
          ];
          
          document.documentElement.animate(
            {
              clipPath: clipPath,
            },
            {
              duration: 800,
              easing: 'cubic-bezier(0.65, 0, 0.35, 1)',
              pseudoElement: '::view-transition-new(root)',
            }
          );
        });
      };
    </script>
  </body>
</html>