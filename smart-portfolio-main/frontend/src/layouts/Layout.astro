---
import "@/styles/style.css";
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MorningStar | Developer",
  description = "Developer specializing in frontend architecture, React, and AI.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0&icon_names=waving_hand"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0&icon_names=handshake"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0&icon_names=rocket_launch"
    />
    <title>{title}</title>
    <style is:global>
      :root {
        --font-mono: "JetBrains Mono", monospace;
        --font-sans: "Inter", sans-serif;
      }
      body {
        font-family: var(--font-sans);
        /* Cursor restored to default */
        cursor: auto;
      }
      /* Ensure interactive elements use standard pointers */
      a,
      button,
      [role="button"] {
        cursor: pointer !important;
      }
      .font-mono {
        font-family: var(--font-mono);
      }
      .section-bg-layer {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 650ms ease;
      }

      /* View Transition Styles for Theme Toggle */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
      }
      ::view-transition-old(root) {
        z-index: 1;
      }
      ::view-transition-new(root) {
        z-index: 2;
      }

      /* RESPONSIVE OVERRIDES */
      @media (max-width: 1024px) {
        #page-scrollbar {
          display: none !important;
        }
        /* Disable snapping if sections are too tall for small screens to prevent content cutoff */
        body.snap-y {
          scroll-snap-type: none !important;
        }
      }

      @media (max-width: 768px) {
        /* Global Typography Scaling for Mobile */
        h1 {
          font-size: 2.25rem !important;
          line-height: 2.5rem !important;
          letter-spacing: -0.02em !important;
        }
        h2 {
          font-size: 1.75rem !important;
          line-height: 2rem !important;
        }
        h3 {
          font-size: 1.25rem !important;
          line-height: 1.75rem !important;
        }
        p {
          font-size: 0.9375rem !important;
          line-height: 1.5rem !important;
        }

        /* Utility Class Overrides for Mobile */
        .text-6xl {
          font-size: 3rem !important;
          line-height: 1 !important;
        }
        .text-5xl {
          font-size: 2.5rem !important;
          line-height: 1 !important;
        }
        .text-4xl {
          font-size: 2rem !important;
          line-height: 2.25rem !important;
        }

        /* Grid and spacing adjustments */
        .container {
          padding-left: 1.25rem !important;
          padding-right: 1.25rem !important;
        }

        .section-bg-layer {
          background-size: 30px 30px !important;
        }
      }

      @media (max-width: 480px) {
        h1 {
          font-size: 1.875rem !important;
        }
        .text-base {
          font-size: 0.875rem !important;
        }
      }
      body {
        /* Hide native scrollbars but keep functionality */
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE and Edge */
      }

      #section-bg-stage {
        /* The Grid Pattern */
        background-image:
          linear-gradient(
            to right,
            rgba(128, 128, 128, 0.1) 1px,
            transparent 1px
          ),
          linear-gradient(
            to bottom,
            rgba(128, 128, 128, 0.1) 1px,
            transparent 1px
          );
        background-size: 50px 50px;
        /* Optional: adds a subtle fade effect at the edges or bottom */
        mask-image: radial-gradient(
          circle at center,
          black 80%,
          transparent 100%
        );
      }

      /* Adjust grid color for light mode specifically if needed */
      :root:not(.dark) #section-bg-stage {
        background-image:
          linear-gradient(to right, rgba(0, 0, 0, 0.05) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
      }

      /* 2. THE SCROLL ANIMATION */

      /* Define the keyframes for shrinking/growing */
      @keyframes section-reveal {
        0% {
          transform: scale(0.94);
          opacity: 50;
        }
        /* Section is fully in view */
        25%,
        75% {
          transform: scale(1);
          opacity: 1;
        }
        /* Section is scrolling out the top */
        100% {
          transform: scale(0.95);
          opacity: 50;
        }
      }

      /* Apply this to the sections inside your slot */
      /* Note: Ensure your sections have 'snap-align: start' */
      section {
        view-timeline-name: --section-view;
        view-timeline-axis: block;

        /* This ensures the animation is linked to the section's progress through the viewport */
        animation-timeline: --section-view;
        animation-name: section-reveal;
        animation-fill-mode: both;
        animation-timing-function: ease-in-out;

        /* Ensure the transform doesn't cause layout shifting */
        will-change: transform, opacity;
      }

      /* Resetting the default snap behavior to ensure smooth transitions */
      html {
        scroll-padding-top: 0;
      }
    </style>
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return "dark";
      })();
      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body
    class="min-h-screen overflow-x-hidden text-foreground antialiased relative snap-y snap-mandatory"
  >
    <div
      id="section-bg-stage"
      class="fixed inset-0 pointer-events-none z-0 overflow-hidden bg-background"
    >
      <div data-bg-id="default" class="section-bg-layer opacity-100"></div>
    </div>
    <div data-bg-id="about" class="section-bg-layer"></div>
    <div data-bg-id="experience" class="section-bg-layer"></div>
    <div data-bg-id="projects" class="section-bg-layer"></div>
    <div data-bg-id="chat" class="section-bg-layer"></div>
    <div data-bg-id="contact" class="section-bg-layer"></div>
    <div data-bg-id="admin" class="section-bg-layer"></div>
  </body>

  <div class="relative z-10 flex flex-col min-h-screen bg-transparent">
    <slot />
  </div>

  <!-- Page Scrollbar Element -->
  <div
    id="page-scrollbar"
    class="fixed right-1 top-0 bottom-0 w-1.5 z-[9999] pointer-events-auto"
  >
    <div
      class="custom-scrollbar-thumb w-full bg-foreground/20 hover:bg-foreground/40 rounded-full transition-colors cursor-pointer"
    >
    </div>
  </div>
</html>
