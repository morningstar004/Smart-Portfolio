---
const currentYear = new Date().getFullYear();
const buildStamp = new Date().toLocaleString('en-GB', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
  hour12: false
}).replace(/\//g, '.').replace(', ', '_');
---

<footer class="">
  <div class="">
    <div class="">
      <div class="">
        <span class="">ZR_SYSTEMS</span>
        <span class="">ALL_RIGHTS_RESERVED // {currentYear}</span>
      </div>
      
      <div class="">
        <a href="https://github.com/ZRishu" target="_blank" class="">GITHUB</a>
        <a href="https://linkedin.com/in/ZRishu" target="_blank" class="">LINKEDIN</a>
        <a href="https://x.com/ragebyt" target="_blank" class="">X/TWITTER</a>
      </div>

      <div class="text-right">
        <span 
          id="build-stamp" 
          class=""
          title="DBL_CLICK_TO_RESTORE_DARK_MODE"
        >
          BUILD_STAMP: {buildStamp}
        </span>
      </div>
    </div>
  </div>
</footer>

<script>
  function initDarkModeRestore(): void {
    const stamp = document.getElementById("build-stamp");
    const html = document.documentElement;

    if (!stamp) return;

    stamp.addEventListener("dblclick", (e) => {
      // Only trigger if we are currently in light mode
      if (html.classList.contains("dark")) return;

      if (typeof (window as any).toggleTheme === 'function') {
        (window as any).toggleTheme(e, "dark"); 
      }
    });
  }

  initDarkModeRestore(); 
</script>
