<script>
  import { apiUrl } from "../lib/public-api";

  async function loadHero(): Promise<void> {
    const nameEl = document.getElementById("hero-name");
    const taglineEl = document.getElementById("hero-tagline");
    if (!nameEl || !taglineEl) return;

    try {
      const res = await fetch(apiUrl("/api/chat"), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          question:
            "What is the full name of the person in this resume? Reply with ONLY the name, nothing else.",
        }),
      });

      const envelope = await res.json();
      if (envelope.success && envelope.data) {
        nameEl.textContent = envelope.data.answer.trim();
      }
    } catch {}

    try {
      const res = await fetch(apiUrl("/api/chat"), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          question:
            "Write a brief professional summary in under 30 words of the person in this resume. Write in first person. Do not use markdown, keep it as plain text. Focus only on core technical expertise.",
        }),
      });

      const envelope = await res.json();
      if (envelope.success && envelope.data) {
        taglineEl.innerHTML = `<span class="text-brand-orange">></span> ${envelope.data.answer.trim()}<span class="inline-block w-2 h-5 bg-foreground animate-pulse align-middle ml-1"></span>`;
      }
    } catch {
      taglineEl.innerHTML = `<span class="text-brand-orange">></span> I am a Backend Developer specializing in Java, focusing on building high-performance scalable systems and microservices architectures.<span class="inline-block w-2 h-5 bg-foreground animate-pulse align-middle ml-1"></span>`;
    }
  }

  function initModeToggle(): void {
    const trigger = document.getElementById("profile-trigger");
    const hoverOverlay = document.getElementById("hover-overlay");
    const html = document.documentElement;

    if (!trigger || !hoverOverlay) return;

    // Listen for global theme changes to update UI
    document.addEventListener("theme-changed", (e: any) => {
      if (e.detail.theme === "light") {
        hoverOverlay.classList.remove("group-hover:opacity-100");
        trigger.style.cursor = "default";
      } else {
        hoverOverlay.classList.add("group-hover:opacity-100");
        trigger.style.cursor = "pointer";
      }
    });

    // Check if already in light mode on load
    if (!html.classList.contains("dark")) {
      hoverOverlay.classList.remove("group-hover:opacity-100");
      trigger.style.cursor = "default";
      return;
    }

    trigger.addEventListener("click", (e) => {
      if (!html.classList.contains("dark")) return;
      if (typeof (window as any).toggleTheme === "function") {
        (window as any).toggleTheme(e, "light");
      }
    });
  }

  function initSpiderReveal() {
    const trigger = document.getElementById("profile-trigger");
    const revealContainer = document.getElementById("reveal-container");
    const nameDisplay = document.getElementById("name-display");
    const customCursor = document.getElementById("custom-cursor");

    if (!trigger || !revealContainer || !nameDisplay || !customCursor) return;

    const originalName = "Pranjal kumar.";
    const spiderName = "Spider-man";

    const handleMove = (e: MouseEvent) => {
      // 1. Move the visual custom cursor (Global coordinates)
      customCursor.style.left = `${e.clientX}px`;
      customCursor.style.top = `${e.clientY}px`;

      // 2. Update the Reveal Mask (Local coordinates)
      const rect = trigger.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      // Update the circle mask size and position
      // 80px is the radius of the "flashlight"
      revealContainer.style.clipPath = `circle(100px at ${x}px ${y}px)`;
    };

    trigger.addEventListener("mouseenter", () => {
      customCursor.style.opacity = "1";
      nameDisplay.textContent = spiderName;
      nameDisplay.classList.replace("text-amber-400", "text-red-600");
      document.body.style.cursor = "none";
    });

    trigger.addEventListener("mousemove", handleMove);

    trigger.addEventListener("mouseleave", () => {
      customCursor.style.opacity = "0";
      revealContainer.style.clipPath = `circle(0% at 50% 50%)`;
      nameDisplay.textContent = originalName;
      nameDisplay.classList.replace("text-red-600", "text-amber-400");
      document.body.style.cursor = "default";
    });
  }

  initSpiderReveal();

  loadHero();
  initModeToggle();
</script>

<style>
  /* Import only the fonts you need to improve loading speed */
  @import url("https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@800&display=swap");
  @import url("https://fonts.googleapis.com/css2?family=Raleway:wght@400;700&display=swap");
  .profession {
    /* This applies the font to the class already on your div */
    font-family: "M PLUS Rounded 1c", sans-serif;
    font-weight: 800;
    font-style: normal;
  }

  /* Alternatively, you can use the specific class name you provided */
  .m-plus-rounded-1c-extrabold {
    font-family: "M PLUS Rounded 1c", sans-serif;
    font-weight: 800;
    font-style: normal;
  }

  .intro {
    font-family: "Raleway", sans-serif;
    font-weight: 400;
    font-style: normal;
  }

  .description {
    font-family: "Raleway", sans-serif;
    font-weight: 600;
    font-style: normal;
  }

  .myName {
    font-family: "Raleway", sans-serif;
    font-weight: 700;
    font-style: normal;
  }

  .raleway {
    font-family: "Raleway", sans-serif;
    font-optical-sizing: auto;
    font-style: normal;
  }
  .profile-pop-out {
    /* 
       THE MAGIC LINE:
       - The first four values (inset) mean: clip 0% from sides/bottom, but -100% from top (allowing it to grow).
       - 'round 50%' creates the circular clipping at the bottom.
    */
    clip-path: inset(-100% 0% 10% 0% round 100%);

    /* Fine-tune this to adjust how high the head sits */
    transform: translateX(-46%) translateY(21%);
  }
  .profile-pop-out-spider {
    /* 
       THE MAGIC LINE:
       - The first four values (inset) mean: clip 0% from sides/bottom, but -100% from top (allowing it to grow).
       - 'round 50%' creates the circular clipping at the bottom.
    */
    clip-path: inset(-100% 0% 22% 0% round 100%);

    /* Fine-tune this to adjust how high the head sits */
    transform: translateX(-47%) translateY(20%);
  }

  .profession {
    /* This creates the "portal" look - text fades in/out at edges */
    -webkit-mask-image: linear-gradient(
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    mask-image: linear-gradient(transparent, black 15%, black 85%, transparent);
  }

  /* The "Venom" stretch effect */
  .stretching {
    filter: blur(8px) contrast(1.2);
    transform: scaleY(1.1) skewX(-2deg);
    opacity: 0.5;
  }
  #reveal-container {
    /* Transition the clip-path size for smoothness when entering/leaving */
    transition: clip-path 0.25s ease-out;
    /* Important: keep the container overflow visible so the head can still pop out */
    overflow: visible;
  }

  #custom-cursor {
    mix-blend-difference: difference;
    background-color: rgba(135, 49, 49, 0.1);
    backdrop-filter: blur(1px);
    pointer-events: none;
    z-index: 9999;
  }


  #profile-trigger {
    /* Ensure the trigger is the reference point for cursor logic */
    position: relative;
    overflow: visible;
  }

  .myName {
    transition: color 0.3s ease, transform 0.3s ease;
  }
</style>
