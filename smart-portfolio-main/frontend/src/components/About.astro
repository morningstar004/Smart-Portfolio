<style>
  .spider-container {
    cursor: pointer;
    user-select: none;
  }

  /* Default bounce animation for spider */
  .spider-svg {
    animation: gentle-bounce 2s ease-in-out infinite;
    transition:
      transform 0.3s ease,
      filter 0.3s ease;
    transform-origin: top center;
  }

  .thread-line {
    transition:
      height 0.3s ease,
      transform 0.3s ease;
    transform-origin: top center;
  }

  @keyframes gentle-bounce {
    0%,
    100% {
      transform: translateY(-12px);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  /* Hover: spider swings side to side */
  .spider-container:hover .spider-svg {
    animation: swing 1s ease-in-out infinite;
  }

  .spider-container:hover .thread-line {
    animation: thread-swing 1s ease-in-out infinite;
  }

  .spider-container:hover .web-svg {
    filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.3));
    transform: rotate(32deg) scale(1.05);
  }

  @keyframes swing {
    0%,
    100% {
      transform: translateY(-12px) rotate(-15deg);
    }
    50% {
      transform: translateY(-12px) rotate(15deg);
    }
  }

  @keyframes thread-swing {
    0%,
    100% {
      transform: rotate(-8deg);
    }
    50% {
      transform: rotate(8deg);
    }
  }

  /* Click: spider drops down and climbs back up */
  .spider-container.clicked .spider-svg {
    animation: drop-climb 1.5s ease-in-out forwards;
  }

  .spider-container.clicked .thread-line {
    animation: thread-extend 1.5s ease-in-out forwards;
  }

  .spider-container.clicked .web-svg {
    animation:  0.5s ease-in-out;
  }

  @keyframes drop-climb {
    0% {
      transform: translateY(0px);
    }
    30% {
      transform: translateY(0px) rotate(10deg);
    }
    50% {
      transform: translateY(0px) rotate(-10deg);
    }
    100% {
      transform: translateY(0px) rotate(0deg);
    }
  }

  @keyframes thread-extend {
    0% {
      height: 48px;
    }
    30% {
      height: 100px;
    }
    50% {
      height: 100px;
    }
    100% {
      height: 48px;
    }
  }

  @keyframes web-shake {
    0%,
    100% {
      transform: rotate(32deg);
    }
    25% {
      transform: rotate(35deg);
    }
    75% {
      transform: rotate(29deg);
    }
  }

  /* Scared spider on rapid clicks */
  .spider-container.scared .spider-svg {
    animation: scared-shake 0.1s ease-in-out infinite;
  }

  @keyframes scared-shake {
    0%,
    100% {
      transform: translateY(-12px) translateX(-2px);
    }
    50% {
      transform: translateY(-12px) translateX(2px);
    }
  }
</style>
