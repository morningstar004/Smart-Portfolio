        style="clip-path: circle(0% at 50% 50%);"
      />

      <!-- REVEAL IMAGE (Spider-man) -->
      <!-- We wrap it in a div that will be clipped -->
      <div
        id="reveal-container"
        class="absolute inset-0 z-30 pointer-events-none"
        style="clip-path: circle(0% at 50% 50%);"
      >
        <img
          id="profile-img-reveal"
          src="/Spider-man.png"
          alt="Spider-man reveal"
