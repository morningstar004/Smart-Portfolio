    font-style: normal;
  }
  .profile-pop-out {
    /* 
       THE MAGIC LINE:
       - The first four values (inset) mean: clip 0% from sides/bottom, but -100% from top (allowing it to grow).
       - 'round 50%' creates the circular clipping at the bottom.
    */
    clip-path: inset(-100% 0% 10% 0% round 100%);

    /* Fine-tune this to adjust how high the head sits */
    transform: translateX(-46%) translateY(21%);
  }
  .profile-pop-out-spider {
    /* 
       THE MAGIC LINE:
       - The first four values (inset) mean: clip 0% from sides/bottom, but -100% from top (allowing it to grow).
       - 'round 50%' creates the circular clipping at the bottom.
    */
    clip-path: inset(-100% 0% 21% 0% round 100%);

    /* Fine-tune this to adjust how high the head sits */
    transform: translateX(-47%) translateY(20%);
  }

  .profession {
    /* This creates the "portal" look - text fades in/out at edges */
    -webkit-mask-image: linear-gradient(
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    mask-image: linear-gradient(transparent, black 15%, black 85%, transparent);
  }

  /* The "Venom" stretch effect */
  .stretching {
    filter: blur(8px) contrast(1.2);
    transform: scaleY(1.1) skewX(-2deg);
    opacity: 0.5;
  }
  #custom-cursor {
    /* 1. Remove left/top from here */
    position: fixed;
    top: 0;
    left: 0;

    /* 2. Set the initial position to 0 and use transform instead */
    transform: translate3d(0, 0, 0);

    /* 3. Add hardware acceleration */
    will-change: transform;

    /* 4. IMPORTANT: Only transition Opacity and Scale, NOT Transform/Movement */
    transition:
      opacity 0.3s ease,
      scale 0.3s ease-in-out;

    /* Ensure it doesn't block mouse events */
    pointer-events: none;
    z-index: 9999;

    /* Style */
    width: 200px; /* circle(100px) means 200px diameter */
    height: 200px;
    border: 2px solid black;
    border-radius: 50%;
    mix-blend-difference: difference;
  }

  /* Optimize the reveal container too */
  #reveal-container {
    will-change: clip-path;
    pointer-events: none;
  }
  #profile-trigger {
    /* Ensure the trigger is the reference point for cursor logic */
    position: relative;
    overflow: visible;
  }

  /* Ensure both names use the same font so they morph cleanly */
  .myName {
    font-family: "Raleway", sans-serif;
    font-weight: 700;
    font-style: normal;
    /* This prevents the text from "jumping" during the blur phase */
    backface-visibility: hidden;
    pointer-events: none;
  }

  #name-display {
    /* Required to let the "goo" blur extend beyond text boundaries */
    contain: paint;
  }

  /* Match your React component's transition style */
  #name-original,
  #name-spider {
    will-change: opacity, filter;
  }
</style>
