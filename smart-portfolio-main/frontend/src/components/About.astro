  function initSpiderReveal() {
    const trigger = document.getElementById("profile-trigger");
    const revealContainer = document.getElementById("reveal-container");
    const customCursor = document.getElementById("custom-cursor");
    const nameOriginal = document.getElementById("name-original");
    const nameSpider = document.getElementById("name-spider");

    if (
      !trigger ||
      !revealContainer ||
      !customCursor ||
      !nameOriginal ||
      !nameSpider
    )
      return;

    const handleMove = (e: MouseEvent) => {
      const offsetX = e.clientX - 100;
      const offsetY = e.clientY - 100;
      customCursor.style.transform = `translate3d(${offsetX}px, ${offsetY}px, 0)`;

      const rect = trigger.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      revealContainer.style.clipPath = `circle(100px at ${x}px ${y}px)`;
      revealContainer.style.transition = "clip-path 0.15s ease-out";
    };

    trigger.addEventListener("mouseenter", () => {
      customCursor.style.opacity = "1";
      nameOriginal.style.opacity = "0";
      nameSpider.style.opacity = "1";
      document.body.style.cursor = "none";
    });

    trigger.addEventListener("mousemove", handleMove);

    trigger.addEventListener("mouseleave", () => {
      customCursor.style.opacity = "0";
      nameOriginal.style.opacity = "1";
      nameSpider.style.opacity = "0";
      revealContainer.style.clipPath = `circle(0% at 50% 50%)`;
      document.body.style.cursor = "default";
    });
  }

  initSpiderReveal();
</script>

<script>
  const container = document.querySelector(".spider-container");
  let clickCount = 0;
  let clickTimer: ReturnType<typeof setTimeout> | undefined;

  if (container) {
    container.addEventListener("click", () => {
      clickCount++;

      // Reset click count after 1 second of no clicks
      clearTimeout(clickTimer);
      clickTimer = setTimeout(() => {
        clickCount = 0;
        container.classList.remove("scared");
      }, 1000);

      // If clicked rapidly (3+ times), spider gets scared
      if (clickCount >= 3) {
        container.classList.remove("clicked");
        container.classList.add("scared");
        return;
      }

      // Normal click: drop and climb
      container.classList.remove("clicked", "scared");
      // Force reflow to restart animation
      void (container as HTMLElement).offsetWidth;
      container.classList.add("clicked");

      // Remove class after animation completes
      setTimeout(() => {
        container.classList.remove("clicked");
      }, 1500);
    });
  }
</script>

