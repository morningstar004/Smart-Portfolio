import { useState } from 'react';
import { motion } from 'framer-motion';

export const ChatButton = () => {
  const [isClicked, setIsClicked] = useState(false);

  return (
    <motion.a
      href="#chat"
      onMouseDown={() => setIsClicked(true)}
      /* EFFECT 1 & 2: Color Shift & Border Reveal */
      className={`
        relative flex items-center justify-center gap-2 py-4 px-8 
        font-sans font-bold text-sm rounded-full 
        border-2 transition-all duration-300 ease-in-out group
        ${isClicked 
          ? "bg-transparent border-[#388E3C] text-[#388E3C]" // Clicked state (Green)
          : "bg-white border-transparent text-black hover:bg-transparent hover:border-white hover:text-white" // Default to Hover state
        }
      `}
      whileTap={{ scale: 0.95 }}
    >
      {/* EFFECT 3: State Change Indication (Text swap) */}
      <span className="relative z-10">
        {isClicked ? "INITIALIZING CHAT..." : "EXEC AI CHAT"}
      </span>

      {/* SVG Arrow - flips color automatically because of 'text' classes */}
      <svg
        className={`transition-transform duration-300 ${isClicked ? "rotate-45" : "group-hover:translate-x-1 group-hover:-translate-y-1"}`}
        viewBox="0 0 24 24"
        height="20"
        width="20"
        fill="none"
        stroke="currentColor"
        strokeWidth="2.5"
        strokeLinecap="round"
        strokeLinejoin="round"
      >
        <path d="M7 17L17 7M17 7H8M17 7V16" />
      </svg>
    </motion.a>
  );
};