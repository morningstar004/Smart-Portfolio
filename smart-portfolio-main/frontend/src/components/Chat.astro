<section
  id="chat"
  data-bg-layer="chat"
  class="flex flex-col gap-8 mt-60 justify-center items-center max-md:mt-24 max-md:px-4 scroll-mt-35 md:mt-40 lg:mt-60 max-md:gap-6"
>
  <div class="">
    <div class="w-full max-w-full">
      <!-- Info Pane -->
      <div class="">
        <div class="headtop text-center">
          <h2 class="font-semibold text-[#ec7a3d] max-md:text-sm lg:text-base md:text-sm">
            karen
          </h2>
          <h3
            class="text-4xl font-semibold tracking-tight text-gray-900 mb-8 max-md:text-3xl max-sm:text-2xl max-md:mb-6 md:text-4xl md:mb-7"
          >
            AGENT WEBS
          </h3>
        </div>
        <div class="max-sm:w-full flex mx-auto px-4">
          <p
            class="text-gray-700 max-w-3xl text-center mx-auto max-md:text-sm max-md:leading-relaxed max-sm:text-xs md:text-base md:leading-normal"
          >
            Agent Webs is an interactive interface designed to demonstrate the
            capabilities of a resume-grounded agent named "Karen". Made using
            Grok Llama 3 70B, Karen can understand and respond to queries about
            my professional experience, technical skills, and project history
            based on the structured data from my resume.
          </p>
        </div>
      </div>

      <div class="flex mt-12 max-md:mt-0">
        <div>
          <div
            class="absolute translate-x-26.25 -translate-y-2 h-4 w-4 rounded-full bg-gray-300 -z-10 max-lg:hidden"
          >
          </div>
          <div
            class="absolute translate-x-28 -translate-y-1 w-0.5 h-14 bg-gray-300 -z-10 group-hover:h-16 transition-all duration-500 max-lg:hidden"
          >
          </div>
        </div>
        <div>
          <div
            class="absolute translate-x-164.25 -translate-y-2 h-4 w-4 rounded-full bg-gray-300 -z-10 max-lg:hidden"
          >
          </div>
          <div
            class="absolute translate-x-166 -translate-y-1 w-0.5 h-14 bg-gray-300 -z-10 group-hover:h-16 transition-all duration-500 max-lg:hidden"
          >
          </div>
        </div>
      </div>
      <!-- Chat Interface -->
      <div
        id="chat-container"
        class="relative flex flex-col w-full max-w-5xl min-h-120 max-h-130 bg-[#FF5F5F] rounded-[2.5rem] px-4 py-3 md:px-8 md:py-5 shadow-[0_20px_50px_-15px_rgba(255,95,95,0.4)] overflow-hidden font-mono mt-12 max-md:min-h-[500px] max-md:rounded-[1.5rem] max-sm:mt-6 transition-[height,max-height] duration-300 md:max-h-[600px] md:min-h-[550px] lg:max-h-130 lg:min-h-120"
      >
        <!-- Decorative HUD Scanline Effect -->
        <div
          class="absolute inset-0 pointer-events-none opacity-5 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_2px,3px_100%]"
        >
        </div>

        <!-- Header Section -->
        <div class="relative z-10 flex justify-between items-center mb-2 px-2 max-sm:mb-4 md:mb-3">
          <div class="flex items-center gap-3">
            <div
              class="px-3 py-1 bg-white/20 rounded-full border border-white/30 max-sm:px-2"
            >
              <span class="text-[11px] text-white font-bold tracking-widest max-sm:text-[9px] md:text-[10px] lg:text-[11px]"
                >WEBS PROTOCOL V3.0</span
              >
            </div>
            <div class="hidden sm:flex gap-1.5">
              <div class="w-2 h-2 rounded-full bg-[#E3E1D5] animate-pulse">
              </div>
              <div class="w-2 h-2 rounded-full bg-[#edff84]"></div>
              <div class="w-2 h-2 rounded-full bg-[#7EC4CF]"></div>
            </div>
          </div>
          <div
            id="connection-status"
            class="text-[10px] text-[#ffe4e4] opacity-70 uppercase tracking-tighter max-sm:text-[8px] md:text-[9px] lg:text-[10px]"
          >
            Status: <span class="text-white">Active_Link</span>
          </div>
        </div>

        <!-- Main Chat Window -->
        <div
          class="relative flex-1 max-w-183.75 flex flex-col bg-white/10 backdrop-blur-md rounded-[1.8rem] border border-white/20 overflow-hidden shadow-inner max-md:rounded-[1.2rem] md:max-w-full lg:max-w-183.75"
        >
          <div
            id="chat-messages"
            class="flex-1 overflow-y-auto p-6 space-y-8 custom-scrollbar max-sm:p-4 max-sm:space-y-6 md:p-5 md:space-y-7"
          >
            <!-- Initial System Message -->
            <div class="flex gap-4 items-start animate-in fade-in duration-500 max-sm:gap-2 md:gap-3">
              <span
                class="text-[11px] px-2 py-1 bg-[#EC7A3D] text-white font-bold rounded shadow-sm shrink-0 max-sm:text-[9px] md:text-[10px]"
                >WEBS</span
              >
              <div class="relative group max-w-[80%] max-sm:max-w-[85%] md:max-w-[82%]">
                <div
                  class="text-sm leading-relaxed text-gray-800 bg-white/90 rounded-[1.5rem] rounded-tl-none p-4 shadow-sm border border-[#FF5F5F]/80 max-sm:text-xs max-sm:p-3 md:text-[13px] lg:text-sm"
                >
                  SYSTEM_READY. PROTOCOL "WEBS" INITIATED. HOW CAN I ASSIST YOUR
                  INQUIRY, USER?
                </div>
                <span
                  class="absolute -bottom-5 left-2 text-[9px] text-white/60 timestamp-label"
                  >--:--</span
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Input Footer -->
        <div class="relative z-10 mt-2 max-sm:mt-4 md:mt-3">
          <form
            id="chat-form"
            class="flex items-center gap-2 bg-[#ffe4e4] rounded-full p-1 shadow-xl border border-white/30 focus-within:ring-1 ring-white/50 transition-all max-sm:gap-1"
          >
            <div class="pl-4 pr-2 text-[#FF5F5F] font-bold select-none max-sm:pl-3 max-sm:pr-1 max-sm:text-xs md:text-sm">❯</div>
            <input
              type="text"
              id="chat-input"
              placeholder="ENTER_QUERY_HERE..."
              class="flex-1 bg-transparent border-none outline-none focus:ring-0 font-mono text-sm placeholder:text-[#FF5F5F]/40 py-2 text-gray-900 max-sm:text-xs max-sm:py-1.5 md:py-2.5"
              autocomplete="off"
              required
            />
            <button
              type="submit"
              id="chat-submit"
              class="group flex items-center gap-2 px-8 py-3 bg-[#FF5F5F] rounded-full text-white font-bold text-xs tracking-widest transition-all hover:bg-[#ff4646] hover:shadow-lg active:scale-95 max-sm:px-4 max-sm:py-2 max-sm:text-[10px] md:px-6 md:py-2.5"
            >
              <span class="max-sm:hidden">EXECUTE</span>
              <span class="sm:hidden">SEND</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3 w-3 transition-transform group-hover:translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="3"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&display=swap");

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .headtop {
    font-family: "Comfortaa", sans-serif;
    font-style: normal;
  }

  /* Specific logic for when keyboard is open on mobile */
  @media (max-width: 768px) {
    .headtop h2 {
      line-height: 1.2;
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 2px;
    }
    /* Reduce height when keyboard is likely active to ensure input visibility */
    #chat-container.keyboard-active {
      max-height: 60vh !important;
      min-height: 300px !important;
    }
    
    /* Ensure chat bubbles don't get too wide on small screens */
    #chat-messages > div {
      width: 100%;
    }
  }

  @media (max-width: 1024px) {
    #experience {
      overflow-x: hidden;
    }
    
    /* Tablet specific scaling to prevent overflow and maintain aesthetics */
    #chat-container {
      max-width: 95%;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 480px) {
    .custom-scroll-host {
      padding-right: 0px !important;
    }
    
    /* Responsive typography refinement for very small devices */
    #chat-form input::placeholder {
      font-size: 10px;
    }
  }
</style>

<script>
  import { apiUrl } from "../lib/public-api";

  function initChat(): void {
    const form = document.getElementById("chat-form") as HTMLFormElement | null;
    const input = document.getElementById(
      "chat-input",
    ) as HTMLInputElement | null;
    const messages = document.getElementById("chat-messages");
    const submitBtn = document.getElementById(
      "chat-submit",
    ) as HTMLButtonElement | null;
    const chatContainer = document.getElementById("chat-container");
    const chatSection = document.getElementById("chat");

    if (!form || !input || !messages || !submitBtn) return;

    // Mobile Keyboard Handling Logic
    input.addEventListener("focus", () => {
      if (window.innerWidth <= 768) {
        chatContainer?.classList.add("keyboard-active");
        // Delay scroll to ensure the layout has shifted
        setTimeout(() => {
          chatSection?.scrollIntoView({ behavior: "smooth", block: "start" });
        }, 300);
      }
    });

    input.addEventListener("blur", () => {
      chatContainer?.classList.remove("keyboard-active");
    });

    // Set initial timestamp for the hardcoded message
    const initialTime = messages.querySelector(".timestamp-label");
    if (initialTime) initialTime.textContent = getCurrentTime();

    let isStreaming = false;

    function getCurrentTime(): string {
      return new Date().toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    function addMessage(
      role: "USR" | "WEBS",
      text: string,
    ): HTMLElement | null {
      const isUser = role === "USR";
      const wrapper = document.createElement("div");

      wrapper.className = `flex gap-3 animate-in fade-in slide-in-from-bottom-2 duration-300 w-full max-sm:gap-2 ${isUser ? "flex-row-reverse" : "flex-row"}`;

      const roleTag = document.createElement("span");
      roleTag.className = `text-[10px] px-2 py-1 h-fit font-mono font-bold rounded shadow-sm shrink-0 max-sm:text-[9px] ${
        isUser ? "bg-white text-[#FF5F5F]" : "bg-[#EC7A3D] text-white"
      }`;
      roleTag.textContent = role;

      const bubbleContainer = document.createElement("div");
      bubbleContainer.className = `relative group max-w-[80%] flex flex-col overflow-hidden max-sm:max-w-[85%] ${isUser ? "items-end" : "items-start"}`;

      const content = document.createElement("div");
      content.className = `text-sm font-mono leading-relaxed p-4 shadow-md whitespace-pre-wrap break-words max-sm:text-xs max-sm:p-3 ${
        isUser
          ? "bg-[#FF5F5F] text-white rounded-[1.5rem] rounded-tr-none border border-white/20 max-sm:rounded-[1rem] max-sm:rounded-tr-none"
          : "bg-white/90 text-gray-900 rounded-[1.5rem] rounded-tl-none border border-[#FF5F5F]/80 max-sm:rounded-[1rem] max-sm:rounded-tl-none"
      }`;
      content.textContent = text;

      const timeLabel = document.createElement("span");
      timeLabel.className = `absolute -bottom-5 text-[9px] opacity-70 whitespace-nowrap ${isUser ? "right-2 text-white" : "left-2 text-white/60"}`;
      timeLabel.textContent = getCurrentTime();

      bubbleContainer.appendChild(content);
      bubbleContainer.appendChild(timeLabel);

      wrapper.appendChild(roleTag);
      wrapper.appendChild(bubbleContainer);

      messages!.appendChild(wrapper);

      messages!.scrollTo({
        top: messages!.scrollHeight,
        behavior: "smooth",
      });

      return isUser ? null : content;
    }

    async function handleSubmit(e: Event): Promise<void> {
      e.preventDefault();
      if (isStreaming) return;

      const question = input!.value.trim();
      if (!question) return;

      addMessage("USR", question.toUpperCase());
      input!.value = "";
      isStreaming = true;
      submitBtn!.disabled = true;
      submitBtn!.innerHTML = `WAIT... <svg class="animate-spin h-3 w-3 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;

      const botContent = addMessage("WEBS", "");
      if (!botContent) return;
      botContent.classList.add("streaming");

      try {
        const response = await fetch(apiUrl("/api/chat/stream"), {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ question }),
        });

        if (!response.ok || !response.body) throw new Error();

        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let fullText = "";
        let buffer = "";

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split("\n");
          buffer = lines.pop() ?? "";

          for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed) continue;
            if (trimmed.startsWith("event: done")) break;

            if (trimmed.startsWith("data: ")) {
              let text = trimmed.slice(6);
              try {
                text = JSON.parse(`"${text}"`);
              } catch (e) {
                text = text.replace(/\\n/g, "\n");
              }
              fullText += text;
              botContent.textContent = fullText;
              messages!.scrollTop = messages!.scrollHeight;
            }
          }
        }
      } catch (err) {
        botContent.textContent =
          "ERROR: INTERFACE_TIMEOUT_OR_CONNECTION_FAILURE.";
      } finally {
        botContent.classList.remove("streaming");
        isStreaming = false;
        submitBtn!.disabled = false;
        submitBtn!.innerHTML = `EXECUTE <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>`;
        input!.focus();
      }
    }

    form.addEventListener("submit", (e: Event) => {
      void handleSubmit(e);
    });
  }

  initChat();
</script>