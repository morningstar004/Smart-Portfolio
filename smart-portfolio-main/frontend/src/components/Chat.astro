---

---

<section
  id="chat"
  data-bg-layer="chat"
  class="flex flex-col gap-8 mt-60 justify-center items-center max-md:mt-24 max-md:px-4"
>
  <div class="">
    <div class="w-full">
      <!-- Info Pane -->
      <div class="">
        <div class="headtop text-center">
          <h2 class="font-semibold text-[#ec7a3d] max-md:text-sm lg:text-base">
            karen
          </h2>
          <h3
            class="text-4xl font-semibold tracking-tight text-gray-900 mb-8 max-md:text-3xl max-sm:text-2xl max-md:mb-6"
          >
            AGENT WEBS
          </h3>
        </div>
        <div class="max-sm:w-3/4 flex mx-auto">
          <p
            class="text-gray-700 max-w-3xl text-center mx-auto max-md:text-sm max-md:leading-relaxed max-sm:text-xs"
          >
            Agent Webs is an interactive interface designed to demonstrate the
            capabilities of a resume-grounded agent named "Karen". Made using
            Grok Llama 3 70B, Karen can understand and respond to queries about
            my professional experience, technical skills, and project history
            based on the structured data from my resume.
          </p>
        </div>
      </div>

      <div class="flex mt-12">
        <div>
          <div
            class="absolute translate-x-26.25 -translate-y-2 h-4 w-4 rounded-full bg-gray-300 -z-10 max-lg:"
          >
          </div>
          <div
            class="absolute translate-x-28 -translate-y-1 w-0.5 h-14 bg-gray-300 -z-10 group-hover:h-16 transition-all duration-500"
          >
          </div>
        </div>
        <div>
          <div
            class="absolute translate-x-164.25 -translate-y-2 h-4 w-4 rounded-full bg-gray-300 -z-10 max-lg:"
          >
          </div>
          <div
            class="absolute translate-x-166 -translate-y-1 w-0.5 h-14 bg-gray-300 -z-10 group-hover:h-16 transition-all duration-500"
          >
          </div>
        </div>
      </div>
      <!-- Chat Interface -->
      <div
        class="relative flex flex-col w-full max-w-5xl min-h-120 max-h-130 bg-[#FF5F5F] rounded-[2.5rem] px-4 py-3 md:px-8 md:py-5 shadow-[0_20px_50px_-15px_rgba(255,95,95,0.4)] overflow-hidden font-mono mt-12"
      >
        <!-- Decorative HUD Scanline Effect -->
        <div
          class="absolute inset-0 pointer-events-none opacity-5 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_2px,3px_100%]"
        >
        </div>

        <!-- Header Section -->
        <div class="relative z-10 flex justify-between items-center mb-2 px-2">
          <div class="flex items-center gap-3">
            <div
              class="px-3 py-1 bg-white/20 rounded-full border border-white/30"
            >
              <span class="text-[11px] text-white font-bold tracking-widest"
                >WEBS PROTOCOL V3.0</span
              >
            </div>
            <div class="hidden sm:flex gap-1.5">
              <div class="w-2 h-2 rounded-full bg-[#E3E1D5] animate-pulse">
              </div>
              <div class="w-2 h-2 rounded-full bg-[#edff84]"></div>
              <div class="w-2 h-2 rounded-full bg-[#7EC4CF]"></div>
            </div>
          </div>
          <div
            id="connection-status"
            class="text-[10px] text-[#ffe4e4] opacity-70 uppercase tracking-tighter"
          >
            Status: <span class="text-white">Active_Link</span>
          </div>
        </div>

        <!-- Main Chat Window -->
        <div
          class="relative flex-1 flex flex-col bg-white/10 backdrop-blur-md rounded-[1.8rem] border border-white/20 overflow-hidden shadow-inner"
        >
          <div
            id="chat-messages"
            class="flex-1 overflow-y-auto p-6 space-y-8 custom-scrollbar"
          >
            <!-- Initial System Message -->
            <div class="flex gap-4 items-start animate-in fade-in duration-500">
              <span
                class="text-[11px] px-2 py-1 bg-[#EC7A3D] text-white font-bold rounded shadow-sm shrink-0"
                >WEBS</span
              >
              <div class="relative group max-w-[80%]">
                <div
                  class="text-sm leading-relaxed text-gray-800 bg-white/90 rounded-[1.5rem] rounded-tl-none p-4 shadow-sm border border-[#FF5F5F]/80"
                >
                  SYSTEM_READY. PROTOCOL "WEBS" INITIATED. HOW CAN I ASSIST YOUR
                  INQUIRY, USER?
                </div>
                <span
                  class="absolute -bottom-5 left-2 text-[9px] text-white/60 timestamp-label"
                  >--:--</span
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Input Footer -->
        <div class="relative z-10 mt-2">
          <form
            id="chat-form"
            class="flex items-center gap-2 bg-[#ffe4e4] rounded-full p-1 shadow-xl border border-white/30 focus-within:ring-1 ring-white/50 transition-all"
          >
            <div class="pl-4 pr-2 text-[#FF5F5F] font-bold select-none">❯</div>
            <input
              type="text"
              id="chat-input"
              placeholder="ENTER_QUERY_HERE..."
              class="flex-1 bg-transparent border-none outline-none focus:ring-0 font-mono text-sm placeholder:text-[#FF5F5F]/40 py-2 text-gray-900"
              autocomplete="off"
              required
            />
            <button
              type="submit"
              id="chat-submit"
              class="group flex items-center gap-2 px-8 py-3 bg-[#FF5F5F] rounded-full text-white font-bold text-xs tracking-widest transition-all hover:bg-[#ff4646] hover:shadow-lg active:scale-95"
            >
              EXECUTE
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3 w-3 transition-transform group-hover:translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="3"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&display=swap");

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .headtop {
    font-family: "Comfortaa", sans-serif;
    font-style: normal;
  }

  @media (max-width: 1024px) {
    #experience {
      overflow-x: hidden;
    }
  }

  @media (max-width: 768px) {
    .headtop h2 {
      line-height: 1.2;
    }
  }

  @media (max-width: 480px) {
    .custom-scroll-host {
      padding-right: 0px !important;
    }
  }
</style>

<script>
  import { apiUrl } from "../lib/public-api";

  function initChat(): void {
    const form = document.getElementById("chat-form") as HTMLFormElement | null;
    const input = document.getElementById(
      "chat-input",
    ) as HTMLInputElement | null;
    const messages = document.getElementById("chat-messages");
    const submitBtn = document.getElementById(
      "chat-submit",
    ) as HTMLButtonElement | null;

    if (!form || !input || !messages || !submitBtn) return;

    // Set initial timestamp for the hardcoded message
    const initialTime = messages.querySelector(".timestamp-label");
    if (initialTime) initialTime.textContent = getCurrentTime();

    let isStreaming = false;

    function getCurrentTime(): string {
      return new Date().toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    function addMessage(
      role: "USR" | "WEBS",
      text: string,
    ): HTMLElement | null {
      const isUser = role === "USR";
      const wrapper = document.createElement("div");

      // Layout: flex-row-reverse for user to put icon on right and align bubble right
      wrapper.className = `flex gap-3 animate-in fade-in slide-in-from-bottom-2 duration-300 w-full ${isUser ? "flex-row-reverse" : "flex-row"}`;

      const roleTag = document.createElement("span");
      roleTag.className = `text-[10px] px-2 py-1 h-fit font-mono font-bold rounded shadow-sm shrink-0 ${
        isUser ? "bg-white text-[#FF5F5F]" : "bg-[#EC7A3D] text-white"
      }`;
      roleTag.textContent = role;

      const bubbleContainer = document.createElement("div");
      bubbleContainer.className = `relative group max-w-[80%] flex flex-col ${isUser ? "items-end" : "items-start"}`;

      const content = document.createElement("div");
      content.className = `text-sm font-mono leading-relaxed p-4 shadow-md whitespace-pre-wrap ${
        isUser
          ? "bg-[#FF5F5F] text-white rounded-[1.5rem] rounded-tr-none border border-white/20"
          : "bg-white/90 text-gray-900 rounded-[1.5rem] rounded-tl-none border border-[#FF5F5F]/80"
      }`;
      content.textContent = text;

      const timeLabel = document.createElement("span");
      timeLabel.className = `absolute -bottom-5 text-[9px] opacity-70 whitespace-nowrap ${isUser ? "right-2 text-white" : "left-2 text-white/60"}`;
      timeLabel.textContent = getCurrentTime();

      bubbleContainer.appendChild(content);
      bubbleContainer.appendChild(timeLabel);

      wrapper.appendChild(roleTag);
      wrapper.appendChild(bubbleContainer);

      messages!.appendChild(wrapper);

      // Smooth scroll to bottom
      messages!.scrollTo({
        top: messages!.scrollHeight,
        behavior: "smooth",
      });

      return isUser ? null : content;
    }

    async function handleSubmit(e: Event): Promise<void> {
      e.preventDefault();
      if (isStreaming) return;

      const question = input!.value.trim();
      if (!question) return;

      addMessage("USR", question.toUpperCase());
      input!.value = "";
      isStreaming = true;
      submitBtn!.disabled = true;
      submitBtn!.textContent = "WAIT...";

      const botContent = addMessage("WEBS", "");
      if (!botContent) return;
      botContent.classList.add("streaming");

      try {
        const response = await fetch(apiUrl("/api/chat/stream"), {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ question }),
        });

        if (!response.ok || !response.body) throw new Error();

        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let fullText = "";
        let buffer = "";

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split("\n");
          buffer = lines.pop() ?? "";

          for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed) continue;
            if (trimmed.startsWith("event: done")) break;

            if (trimmed.startsWith("data: ")) {
              let text = trimmed.slice(6);
              try {
                // Handle JSON escaped newlines if the API sends them
                text = JSON.parse(`"${text}"`);
              } catch (e) {
                text = text.replace(/\\n/g, "\n");
              }
              fullText += text;
              botContent.textContent = fullText;
              messages!.scrollTop = messages!.scrollHeight;
            }
          }
        }
      } catch (err) {
        botContent.textContent =
          "ERROR: INTERFACE_TIMEOUT_OR_CONNECTION_FAILURE.";
      } finally {
        botContent.classList.remove("streaming");
        isStreaming = false;
        submitBtn!.disabled = false;
        submitBtn!.textContent = "EXECUTE";
        input!.focus();
      }
    }

    form.addEventListener("submit", (e: Event) => {
      void handleSubmit(e);
    });
  }

  initChat();
</script>
