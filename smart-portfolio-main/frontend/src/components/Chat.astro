---

<section id="chat" data-bg-layer="chat" class="flex flex-col gap-8 mt-60 justify-center items-center">
  <div class="">
    <div class="w-full">
      <!-- Info Pane -->
      <div class="">
        <div class="headtop text-center">
          <h2 class="font-semibold text-[#ec7a3d] max-md:text-sm lg:text-base">karen</h2>
          <h3 class="text-4xl font-semibold tracking-tight text-gray-900 mb-8 max-md:text-3xl max-sm:text-2xl max-md:mb-6">AGENT WEBS</h3>
        </div>
        <div class="max-sm:w-3/4 flex mx-auto">
          <p class="text-gray-700 max-w-3xl text-center mx-auto max-md:text-sm max-md:leading-relaxed max-sm:text-xs">
             Agent Webs is an interactive interface designed to demonstrate the capabilities of a resume-grounded agent named "Karen". Made using Grok Llama 3 70B, Karen can understand and respond to queries about my professional experience, technical skills, and project history based on the structured data from my resume.
          </p>
        </div>
      </div>

      <!-- Chat Interface -->
      <div class="min-h-[380px] w-5xl max-w-5xl rounded-lg bg-white/40 p-6 flex flex-col gap-6 mt-12">
        <div class="">
          <span class="">SESSION_ID: {Math.random().toString(36).substring(7).toUpperCase()}</span>
          <div class="">
            <div class=""></div>
            <div class=""></div>
            <div class=""></div>
          </div>
        </div>

        <div class="">
          <span id="connection-status" class="">ONLINE_READY</span>
          <div id="chat-messages" class="">
            <div class="">
              <span class="">[BOT]</span>
              <div class="">
                SYSTEM_READY. HOW CAN I ASSIST YOUR INQUIRY?
              </div>
            </div>
          </div>
          <div class="" data-scrollbar-for="chat-messages" data-scrollbar-orientation="vertical">
            <div class="">
              <div class=""></div>
            </div>
          </div>
        </div>

        <div class="">
          <form id="chat-form" class="">
            <span class=""></span>
            <input 
              type="text" 
              id="chat-input"
              placeholder="ENTER_QUERY_HERE..." 
              class=""
              autocomplete="off"
              required
            />
            <button 
              type="submit" 
              id="chat-submit"
              class=""
            >
              EXECUTE
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .streaming::after {
    content: "▋";
    animation: blink 1s step-end infinite;
    display: inline-block;
    width: 6px;
    height: 12px;
    margin-left: 4px;
    background-color: var(--foreground);
    vertical-align: middle;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
</style>

<script>
  import { apiUrl } from "../lib/public-api";

  function initChat(): void {
    const form = document.getElementById("chat-form") as HTMLFormElement | null;
    const input = document.getElementById("chat-input") as HTMLInputElement | null;
    const messages = document.getElementById("chat-messages");
    const submitBtn = document.getElementById("chat-submit") as HTMLButtonElement | null;
    const connStatus = document.getElementById("connection-status");

    if (!form || !input || !messages || !submitBtn) return;

    let isStreaming = false;

    // Validation logic for hover effect
    submitBtn.addEventListener("mouseenter", () => {
      if (input.value.trim() !== "" && !isStreaming) {
        submitBtn.classList.add("bg-brand-green", "text-white");
        submitBtn.classList.remove("bg-foreground", "text-background");
      }
    });

    submitBtn.addEventListener("mouseleave", () => {
      submitBtn.classList.remove("bg-brand-green", "text-white");
      submitBtn.classList.add("bg-foreground", "text-background");
    });

    function addMessage(role: "USR" | "BOT", text: string): HTMLElement | null {
      const wrapper = document.createElement("div");
      wrapper.className = "flex gap-4";
      
      const roleTag = document.createElement("span");
      roleTag.className = `text-[10px] font-mono mt-1 ${role === 'USR' ? 'text-brand-orange' : 'text-brand-green'}`;
      roleTag.textContent = `[${role}]`;
      
      const content = document.createElement("div");
      content.className = `text-sm font-mono leading-relaxed max-w-xl whitespace-pre-wrap ${role === 'USR' ? 'text-muted-foreground' : 'text-foreground'}`;
      content.textContent = text;
      
      wrapper.appendChild(roleTag);
      wrapper.appendChild(content);
      messages!.appendChild(wrapper);
      messages!.scrollTop = messages!.scrollHeight;
      
      return role === 'BOT' ? content : null;
    }

    async function handleSubmit(e: Event): Promise<void> {
      e.preventDefault();
      if (isStreaming) return;

      const question = input!.value.trim();
      if (!question) return;

      addMessage("USR", question.toUpperCase());
      input!.value = "";
      isStreaming = true;
      submitBtn!.disabled = true;
      submitBtn!.textContent = "WAIT...";

      const botContent = addMessage("BOT", "");
      if (!botContent) return;
      botContent.classList.add("streaming");

      try {
        const response = await fetch(apiUrl("/api/chat/stream"), {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ question }),
        });

        if (!response.ok || !response.body) throw new Error();

        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let fullText = "";
        let buffer = "";

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split(" \n");
          buffer = lines.pop() ?? " ";

          for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed) continue;

            if (trimmed.startsWith("event: done")) {
              break;
            }

            if (trimmed.startsWith("data: ")) {
              let text = trimmed.slice(6);
              // Unescape "\\n" sequence sent by the backend.
              text = text.replace(/\\n/g, '\n');
              fullText += text;
              botContent.textContent = fullText;
              messages!.scrollTop = messages!.scrollHeight;
            }
          }
        }
        
        if (connStatus) {
          connStatus.textContent = "ONLINE_READY";
          connStatus.className = "text-brand-green";
        }
      } catch {
        botContent.textContent = "ERROR: INTERFACE_TIMEOUT__OR_CONNECTION_FAILURE.";
        if (connStatus) {
          connStatus.textContent = "OFFLINE_FAILURE";
          connStatus.className = "text-brand-red";
        }
      } finally {
        botContent.classList.remove("streaming");
        isStreaming = false;
        submitBtn!.disabled = false;
        submitBtn!.textContent = "EXECUTE";
        input!.focus();
      }
    }

    form.addEventListener("submit", (e: Event) => {
      void handleSubmit(e);
    });
  }

  initChat();
</script>

<style>
@import url('https://fonts.googleapis.com/css2?family=Aldrich&family=Bebas+Neue&family=Boldonse&family=Caveat+Brush&family=Comfortaa:wght@300..700&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Lilita+One&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Raleway:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap');

.headtop{
  font-family: "Comfortaa", sans-serif;
  font-style: normal;
}

@media (max-width: 1024px) {
  #experience {
    overflow-x: hidden;
  }
}

@media (max-width: 768px) {
  .headtop h2 {
    /* Ensuring the 4xl doesn't cause overflow on narrow tablets */
    line-height: 1.2;
  }
}

@media (max-width: 480px) {
  /* Scale down spacing for small mobile devices */
  .custom-scroll-host {
    padding-right: 0px !important;
  }
}

</style>