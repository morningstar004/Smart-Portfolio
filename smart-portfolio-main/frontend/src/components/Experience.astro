---
import ExperienceList, { type ExperienceItem } from "./solid/ExperienceList";

const fallbackExperience = [ 
  {
    company: "SYSTEM_NODE_ALPHA",
    role: "BACKEND_ENGINEER",
    period: "2023_PRESENT",
    summary:
      "Built backend services and API workflows focused on Java, distributed systems, and production-grade integrations.",
    stack: ["JAVA", "SPRING_BOOT", "POSTGRESQL", "DOCKER"],
  },
  {
    company: "SYSTEM_NODE_BETA",
    role: "SOFTWARE_ENGINEER",
    period: "2021_2023",
    summary:
      "Worked across service development, data pipelines, and deployment automation with an emphasis on reliability and scalability.",
    stack: ["GO", "PYTHON", "KAFKA", "KUBERNETES"],
  },
 ] satisfies ExperienceItem[];
---

<section id="experience" data-bg-layer="experience" class="mt-14 max-md:mt-8">
  <div class="max-lg:px-6 max-sm:px-4">
    <div class="headtop text-center">
      <h3 class="font-semibold text-[#ec7a3d] max-md:text-sm">my journey</h3> 
      <h2 class="text-4xl font-semibold tracking-tight text-gray-900 mb-8 max-md:text-3xl max-sm:text-2xl max-md:mb-6">
        Experience
      </h2>
    </div>

    <div class="custom-scroll-host pr-4 max-sm:pr-0">
      <ExperienceList client:load items={fallbackExperience} />
      <div class="" data-scrollbar-for="experience-list" data-scrollbar-orientation="vertical">
        
      </div>
    </div>
  </div>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Aldrich&family=Bebas+Neue&family=Boldonse&family=Caveat+Brush&family=Comfortaa:wght@300..700&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Lilita+One&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Raleway:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap');

.headtop{
  font-family: "Comfortaa", sans-serif;
  font-style: normal;
}

@media (max-width: 1024px) {
  #experience {
    overflow-x: hidden;
  }
}

@media (max-width: 768px) {
  .headtop h2 {
    /* Ensuring the 4xl doesn't cause overflow on narrow tablets */
    line-height: 1.2;
  }
}

@media (max-width: 480px) {
  /* Scale down spacing for small mobile devices */
  .custom-scroll-host {
    padding-right: 0px !important;
  }
}

</style>