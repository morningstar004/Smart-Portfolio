---
import MotionLink from "./react/MotionLink";
import SponsorButton from "./react/SponsorButton";

interface Props {
  showSectionNav?: boolean;
}

const navLinks: { href: string; label: string }[] = [
  { href: "#about", label: "ABOUT" },
  { href: "#experience", label: "EXPERIENCE" },
  { href: "#projects", label: "PROJECTS" },
  { href: "#contact", label: "CONTACT" },
];

const { showSectionNav = true } = Astro.props;
---

<header class="sticky top-0 z-50 w-full">
  <div class="flex items-center justify-between py-4 px-6">
    <div class="gap-8">
      <a href="/" class="profile name">
        
      </a>
      {showSectionNav && (
        <nav class="hidden">
          {navLinks.map((link) => (
            <a 
              href={link.href} 
              class=""
            >
              {link.label}
            </a>
          ))}
        </nav>
      )}
    </div>

    <div class="">
      <SponsorButton client:load />
      {showSectionNav ? (
        <MotionLink
          client:load
          href="#chat"
          className=""
        >
          EXEC_AI_CHAT
        </MotionLink>
      ) : (
        <MotionLink
          client:load
          href="/"
          className=""
        >
          RETURN_HOME
        </MotionLink>
      )}
      
      
</header>
