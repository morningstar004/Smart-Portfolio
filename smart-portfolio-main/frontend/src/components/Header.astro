---
import MotionLink from "./react/MotionLink";
import SponsorButton from "./react/SponsorButton";

interface Props {
  showSectionNav?: boolean;
}

const navLinks: { href: string; label: string }[] = [
  { href: "#about", label: "ABOUT" },
  { href: "#experience", label: "EXPERIENCE" },
  { href: "#projects", label: "PROJECTS" },
  { href: "#contact", label: "CONTACT" },
];

const { showSectionNav = true } = Astro.props;
---

<header
  class="sticky top-0 z-50 h-24 w-full bg-[#EAF5EB]/40 backdrop-blur-md shadow-sm border-b border-[#388E3C]/20"
>
  <!-- Container -->
  <div class="max-w-7xl mx-auto h-full px-6 grid grid-cols-3 items-center">
    <!-- 1. LEFT: Logo -->
    <div class="flex justify-start">
      <a
        href="/"
        class="font-mono font-bold text-2xl tracking-tighter transition-colors"
      >
        Morning<span class="text-[#388E3C]">Star</span>
      </a>
    </div>

    <!-- 2. CENTER: Navigation -->
    <div class="flex justify-center items-center">
      {
        showSectionNav && (
          <nav class="hidden md:flex items-center gap-8">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class="group relative inline-flex items-center overflow-hidden py-0 cursor-pointer"
              >
                {link.label.split("").map((char, index) => {
                  const centerIndex = (link.label.length - 1) / 2;

                  const distanceFromCenter = Math.abs(
                    index - centerIndex * Math.random(),
                  );

                  const delay = Math.pow(distanceFromCenter, 1) * 50;

                  return (
                    <span
                      key={index}
                      style={{
                        transitionDelay: `${delay}ms`,
                      }}
                      class="relative inline-block transition-transform duration-400 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full"
                    >
                      <span class="lg:text-[13px] tracking-[0.2em] font-bold uppercase text-gray-700">
                        {char === " " ? "\u00A0" : char}
                      </span>

                      <span class="absolute top-full left-0 lg:text-[13px] tracking-[0.2em] font-bold uppercase text-[#388E3C]">
                        {char === " " ? "\u00A0" : char}
                      </span>
                    </span>
                  );
                })}
              </a>
            ))}
          </nav>
        )
      }
    </div>

    <!-- 3. RIGHT: Buttons -->
    <div class="flex justify-end items-center gap-3">
      <SponsorButton client:load />
      {
        showSectionNav ? (
          <MotionLink
            client:load
            href="#chat"
            className="px-4 py-2 bg-[#388E3C] text-white font-mono text-[11px] font-bold tracking-widest hover:bg-black transition-all uppercase rounded-sm"
          >
            EXEC_AI_CHAT
          </MotionLink>
        ) : (
          <MotionLink
            client:load
            href="/"
            className="px-4 py-2 bg-gray-900 text-white font-mono text-[11px] font-bold tracking-widest hover:bg-[#388E3C] transition-all uppercase rounded-sm"
          >
            RETURN_HOME
          </MotionLink>
        )
      }
    </div>
  </div>
</header>
