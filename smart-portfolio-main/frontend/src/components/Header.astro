---
import MotionLink from "./react/MotionLink";
import SponsorButton from "./react/SponsorButton";

interface Props {
  showSectionNav?: boolean;
}

const navLinks: { href: string; label: string }[] = [
  { href: "#about", label: "ABOUT" },
  { href: "#experience", label: "EXPERIENCE" },
  { href: "#projects", label: "PROJECTS" },
  { href: "#contact", label: "CONTACT" },
];

const { showSectionNav = true } = Astro.props;
---

<header
  class="sticky top-0 z-50 h-30 w-full bg-[#EAF5EB]/40 backdrop-saturate-80 backdrop-blur-md shadow-sm border-b border-[#388E3C]/20"
>
  <!-- Container -->
  <div class="max-w-7xl mx-auto h-full px-6 grid grid-cols-3 items-center">
    <!-- 1. LEFT: Logo -->
    <div class="flex justify-start">
      <a
        href="/"
        class="font-mono font-bold text-2xl tracking-tighter transition-colors"
      >
        Morning<span class="text-[#388E3C]">Star</span>
      </a>
    </div>
    
    <!-- 2. CENTER: Navigation -->
    <div class="flex justify-center items-center">
  {
    showSectionNav && (
      <nav class="hidden md:flex items-center gap-8 max-lg:gap-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="group relative inline-flex items-center overflow-hidden py-0 cursor-pointer"
          >
            {link.label.split("").map((char, index) => {
              const centerIndex = (link.label.length - 1) / 2;

              const distanceFromCenter = Math.abs(
                index - centerIndex * Math.random(),
              );

              const delay = Math.pow(distanceFromCenter, 1) * 50;

              return (
                <span
                  style={{
                    transitionDelay: `${delay}ms`,
                  }}
                  class="relative inline-block transition-transform duration-400 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full"
                >
                  <span class="lg:text-[13px] md:text-[11px] tracking-widest font-bold uppercase text-gray-900">
                    {char === " " ? "\u00A0" : char}
                  </span>

                  <span class="absolute top-full left-0 lg:text-[13px] md:text-[11px] tracking-[0.2em] font-bold uppercase text-[#388E3C]">
                    {char === " " ? "\u00A0" : char}
                  </span>
                </span>
              );
            })}
          </a>
        ))}
      </nav>
    )
  }
  </div>


<!-- 3. RIGHT: Buttons -->
<div class="flex justify-end items-center gap-3 max-sm:gap-2">
  <SponsorButton client:load />
  {
    showSectionNav ? (
      <MotionLink
        client:load
        href="#chat"
        className="group active:bg-[#BDDBD0] relative p-[1.2px] max-md:p-px flex items-center justify-center rounded-full overflow-hidden transition-all duration-300"
      >
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[200%] aspect-square animate-[spin_4s_linear_infinite] bg-[conic-gradient(from_0deg,transparent_180deg,#ff4d00_270deg,transparent_360deg)]" />

        <div class="relative z-10 w-full h-full bg-white text-black flex items-center gap-2 max-md:gap-1.5 py-4 px-5 max-md:py-2.5 max-md:px-4 max-sm:py-2 max-sm:px-3 font-sans font-bold text-sm max-md:text-xs max-sm:text-[10px] rounded-full transition-all duration-300">
          <!-- STAGGERED ALPHABET SLIDE EFFECT -->
          <span class="inline-flex overflow-hidden">
            {"EXEC AI CHAT".split("").map((char, index) => {
              const labelLength = "EXEC AI CHAT".length;
              const centerIndex = (labelLength - 1) / 2;
              const distanceFromCenter = Math.abs(index - centerIndex * Math.random());
              const delay = Math.pow(distanceFromCenter, 1) * 50;

              return (
                <span
                  style={{ transitionDelay: `${delay}ms` }}
                  class="relative inline-block transition-transform duration-400 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full"
                >
                  <span class="inline-block">
                    {char === " " ? "\u00A0" : char}
                  </span>
                  <span class="absolute top-full left-0 text-[#388E3C] inline-block">
                    {char === " " ? "\u00A0" : char}
                  </span>
                </span>
              );
            })}
          </span>

          <svg
            viewBox="0 0 24 24"
            height="20"
            width="20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 max-md:w-4 max-md:h-4 max-sm:w-3.5 max-sm:h-3.5"
          >
            <path d="M7 17L17 7M17 7H8M17 7V16" />
          </svg>
        </div>
      </MotionLink>
    ) : (
      <MotionLink
        client:load
        href="/"
        className="bg-white py-4 px-5 max-md:py-2.5 max-md:px-4 max-sm:py-2 max-sm:px-3 font-sans font-bold text-sm max-md:text-xs max-sm:text-[10px] rounded-full "
      >
        RETURN_HOME
      </MotionLink>
    )
  }
</div>
</header>