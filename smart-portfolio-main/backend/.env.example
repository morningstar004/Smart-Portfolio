# =============================================================================
# Smart Portfolio — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]. All others have sensible
# defaults and can be omitted for local development.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
# Port the HTTP server listens on.
SERVER_PORT=8080

# Set to "production" for JSON log output; any other value uses pretty console logs.
ENV=development

# Set to "debug" for verbose log output (includes cache hits, SQL details, etc.)
LOG_LEVEL=debug

# ── Database [REQUIRED] ─────────────────────────────────────────────────────
# PostgreSQL connection string. The database MUST have the pgvector extension.
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://portfolio:portfolio_secret@localhost:5432/smart_portfolio?sslmode=disable

# Connection pool tuning (optional — sensible defaults are used if omitted)
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MIN=30

# ── AI / LLM — Groq (OpenAI-compatible) [REQUIRED] ─────────────────────────
# Get a free API key at https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_TEMPERATURE=0.3

# ── Embeddings — Jina [REQUIRED] ────────────────────────────────────────────
# Get a free API key at https://jina.ai/
JINA_API_KEY=your-jina-api-key-here
JINA_BASE_URL=https://api.jina.ai/v1
EMBEDDING_MODEL=jina-embeddings-v2-base-en
EMBEDDING_DIMENSIONS=768

# ── GitHub Works Sync (optional) ────────────────────────────────────────────
# Used to fetch your public repositories, derive short README summaries, cache
# the selected top repos in PostgreSQL, and store compact GitHub embeddings in
# a dedicated vector table.
#
# GraphQL access requires a token even for public data. A fine-grained token
# with read-only access to public repositories is sufficient.
GITHUB_USERNAME=
GITHUB_API_TOKEN=

# How often the background worker refreshes GitHub data.
GITHUB_SYNC_INTERVAL_HOURS=24

# Number of repositories to keep in the local showcase.
GITHUB_PROJECTS_LIMIT=6

# Number of recent public repositories fetched from GitHub before local ranking.
# GitHub GraphQL requires connection sizes between 1 and 100.
GITHUB_PROJECTS_CANDIDATE_LIMIT=40

# HTTP timeout for GitHub API calls.
GITHUB_API_TIMEOUT_SEC=20

# ── Discord Notifications (optional) ────────────────────────────────────────
# Legacy fallback webhook URL. If you set the two channel-specific webhook URLs
# below, this can stay empty.
DISCORD_WEBHOOK_URL=

# Webhook URL for contact form notifications.
DISCORD_CONTACT_WEBHOOK_URL=

# Webhook URL for payment / sponsor notifications.
DISCORD_PAYMENT_WEBHOOK_URL=

# ── Razorpay Payments (optional) ────────────────────────────────────────────
# Required only if you want to accept sponsorship payments via Razorpay.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Frontend CORS ────────────────────────────────────────────────────────────
# The origin URL of your frontend app. Used for CORS allowed origins.
# Set to "*" to allow all origins (development only — NOT recommended for production).
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum requests per second per IP address.
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# ── Outbox Poller ────────────────────────────────────────────────────────────
# How often (in seconds) the background worker polls for unprocessed outbox events.
OUTBOX_POLL_INTERVAL=10

# ── Cache ────────────────────────────────────────────────────────────────────
# In-memory cache TTL for projects list and other cached data.
CACHE_TTL_HOURS=24
CACHE_MAX_ITEMS=200

# ── Admin Authentication ─────────────────────────────────────────────────────
# Secret API key required to access admin endpoints:
#   - GET  /api/admin/health    (deep health check with DB ping)
#   - GET  /api/admin/stats     (dashboard aggregate statistics)
#   - GET  /api/admin/sponsors  (list all sponsors)
#   - POST /api/ingest          (upload PDF resume for RAG)
#   - POST /api/ingest/text     (ingest raw text for RAG)
#   - DELETE /api/ingest        (clear vector store)
#
# Provide the key in requests via either:
#   X-Admin-Key: <your-key>
#   Authorization: Bearer <your-key>
#
# Leave empty to disable admin authentication (suitable for local development
# only — NEVER leave this empty in production).
ADMIN_API_KEY=
